# Puerto en el que correra el servidor Node.js
PORT=3001

# Entorno de ejecucion (development | production)
NODE_ENV=development

# URL del proyecto obtenida desde el Dashboard de Supabase
SUPABASE_URL=https://tu-proyecto-id.supabase.co

# Llave de rol de servicio (Service Role Key) para operaciones privilegiadas
SUPABASE_SERVICE_KEY=eyJh... (reemplazar con tu llave secreta)